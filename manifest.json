{
  "manifest_version": 3,
  "name": "Black Hole",
  "version": "1.0.0",
  "description": "Suck web page content into a black hole. Click the icon, move your mouse, and watch everything get absorbed!",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Black Hole ON/OFF"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
